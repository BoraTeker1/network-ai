# Network AI — backend environment (example)
# Copy to .env and fill in as features land. Nothing here is required for v1 skeleton.

# SQLite database location (default used by app/db.py if unset)
DATABASE_URL=sqlite:///./network_ai.db

# Source for job ingestion (SimplifyJobs New-Grad-Positions README)
JOBS_README_URL=https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/README.md

# LLM provider key — NOT used in v1. Added here for a later slice.
ANTHROPIC_API_KEY=
